NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy fallback if your Supabase project still uses anon keys.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Jira integration requires no env vars: each user configures their own base URL,
# email, and API token per-user in the app Settings (stored in the integration_jira
# table, protected by RLS). The token is never exposed to the browser.
